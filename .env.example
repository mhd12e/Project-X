# App Mode — controls entire system: "debug" or "production"
APP_MODE=debug

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=projectx
MYSQL_USER=projectx
MYSQL_PASSWORD=changeme
MYSQL_ROOT_PASSWORD=rootchangeme

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Auth
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRATION_SECONDS=900
JWT_REFRESH_EXPIRATION_SECONDS=604800

# Anthropic — Claude Agent SDK uses CLAUDE_CODE_OAUTH_TOKEN (Max subscription)
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# OpenAI (embeddings only)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# Apify (web scraping & data extraction via MCP)
APIFY_TOKEN=

# File storage
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=50

# API
API_PORT=3000
